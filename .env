# 复制为 .env 后按需修改：cp .env.example .env

# 服务监听端口（容器内外一致）
FACE_RECOGNITION_PORT=3080

# Immich Machine Learning 服务地址
# 若 ML 跑在宿主机，Docker 内可改为 http://host.docker.internal:3003
IMMICH_MACHINE_LEARNING=http://127.0.0.1:3003

# 人脸识别模型名称（与 Immich 配置一致）
ML_MODEL_NAME=antelopev2

# PostgreSQL 连接串（Immich 数据库，需支持 pgvector）
# 格式：host=... port=... user=... password=... dbname=... sslmode=disable
# 若 Postgres 跑在宿主机，host 可改为 host.docker.internal
PG_DSN=host=127.0.0.1 port=5432 user=postgres password=postgres dbname=immich sslmode=disable
